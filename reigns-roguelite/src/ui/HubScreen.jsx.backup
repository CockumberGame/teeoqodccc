/**
 * HubScreen - Экран дома (хаб)
 * Gloryhole Quest - управление героиней между ночными сессиями
 * Обновлённый дизайн: компактный инфоблок, оверлей навыков, большая кнопка квеста
 */

import React, { useState } from 'react';
import { useGame } from '../context/GameContext.jsx';

function HubScreen({ onStartNight }) {
  const { state, rest, upgradeSkill, startNight, restoreStamina, restoreMentalHealth, performHomeAction, buyItem } = useGame();
  const { hub, player, phase } = state;
  
  const [notification, setNotification] = useState(null);
  const [showSkillsOverlay, setShowSkillsOverlay] = useState(false);
  const [showShopOverlay, setShowShopOverlay] = useState(false);
  const [performingAction, setPerformingAction] = useState(null);

  // Конвертируем skills из объекта в массив
  const skills = hub?.skills ? Object.values(hub.skills) : [];
  const upgradeCosts = hub?.upgradeCosts || {};
  const inventory = hub?.inventory || [];
  const shopItems = hub?.shopItems || [];
  const canStartNight = hub?.canStartNight !== false;
  const canRest = hub?.canRest || false;
  const sessionCompleted = hub?.sessionCompleted || false;
  const needsRest = hub?.needsRest || false;
  const day = hub?.day || 1;
  const actionPoints = hub?.actionPoints || 3;
  const maxActionPoints = hub?.maxActionPoints || 3;
  const actionPointsBonus = hub?.actionPointsBonus || 0;
  const reputation = hub?.reputation || 0;
  const dailyActions = hub?.dailyActions || {};

  const showNotification = (message, type = 'info') => {
    setNotification({ message, type });
    setTimeout(() => setNotification(null), 3000);
  };

  const handleUpgradeSkill = (skillId) => {
    const result = upgradeSkill(skillId);
    if (result.success) {
      showNotification(`✅ "${getSkillDisplayName(skillId)}" → ур. ${result.newLevel}!`, 'success');
    } else {
      showNotification(`❌ ${result.reason}`, 'error');
    }
  };

  const handleRest = () => {
    const result = rest();
    if (result.success) {
      showNotification(`🌙 День ${result.day} | Восстановлено!`, 'success');
    } else {
      showNotification(`❌ ${result.reason}`, 'error');
    }
  };

  const handleRelax = () => {
    const result = performHomeAction('relax');
    if (result.success) {
      showNotification(result.message || result.effect, 'success');
    } else {
      showNotification(`❌ ${result.reason}`, 'error');
    }
  };

  const handleRestoreStamina = () => {
    const result = restoreStamina(50);
    if (result.success) {
      showNotification(`💤 +${result.restored} стамины (-$${result.cost})`, 'success');
    } else {
      showNotification(`❌ ${result.reason}`, 'error');
    }
  };

  const handleRestoreMental = () => {
    const result = restoreMentalHealth(50);
    if (result.success) {
      showNotification(`🛁 +${result.restored} психики (-$${result.cost})`, 'success');
    } else {
      showNotification(`❌ ${result.reason}`, 'error');
    }
  };

  const handleHomeAction = (actionId, actionName) => {
    if (performingAction) return;

    setPerformingAction({ actionId, actionName });

    setTimeout(() => {
      const result = performHomeAction(actionId);
      setPerformingAction(null);

      if (result.success) {
        showNotification(result.effect || result.message, 'success');
      } else {
        showNotification(`❌ ${result.reason}`, 'error');
      }
    }, 1500);
  };

  const getSkillDisplayName = (skillId) => {
    const skill = skills.find(s => s.id === skillId);
    return skill?.name || skillId;
  };

  const canAffordUpgrade = (skillId) => {
    const cost = upgradeCosts[skillId];
    return player.stats.xp >= cost;
  };

  const isMaxLevel = (skill) => {
    return skill.level >= skill.maxLevel;
  };

  const handleBuyItem = (itemId) => {
    const item = shopItems.find(i => i.id === itemId);
    if (!item) return;

    const result = buyItem(itemId);

    if (result.success) {
      showNotification(`✅ Куплено: ${item.icon} ${item.name} (-$${result.cost})`, 'success');
    } else {
      showNotification(`❌ ${result.reason}`, 'error');
    }
  };

  const canAffordItem = (itemId) => {
    const item = shopItems.find(i => i.id === itemId);
    if (!item) return false;
    return player.stats.money >= item.price;
  };

  const hasItem = (itemId) => {
    return inventory.some(i => i.id === itemId);
  };

  // Доступные действия с энергией
  const energyActions = [
    { id: 'relax', name: 'Расслабиться', icon: '🧘', effect: '+1 ⚡', requiresItem: null },
    { id: 'masturbation', name: 'Ласка', icon: '🔞', effect: '+40 🧠', requiresItem: null },
    { id: 'play_cat', name: 'Кот', icon: '🐱', effect: '+30 💪 +20 🧠', requiresItem: 'cat' },
    { id: 'erotic_chat', name: 'Чат', icon: '📱', effect: '+25 🧠 +15 💪', requiresItem: null }
  ].filter(action => !action.requiresItem || hasItem(action.requiresItem));

  return (
    <div className="hub-screen">
      {/* Уведомления */}
      {notification && (
        <div className={`notification notification-${notification.type}`}>
          {notification.message}
        </div>
      )}

      {/* Логотип игры - кнопка начала */}
      <button
        className="quest-logo-button glow-animation pulse-animation"
        onClick={() => {
          const result = startNight();
          if (result.success && onStartNight) {
            onStartNight();
          } else if (!result.success) {
            showNotification(`❌ ${result.reason}`, 'error');
          }
        }}
        disabled={!canStartNight}
      >
        <div className="quest-logo-content">
          {needsRest && (
            <span className="rest-warning">
              ⚠️ Сначала отдохни!
            </span>
          )}
          {!needsRest && !canStartNight && (
            <span className="rest-warning">
              ⚠️ Нужно 10+ 💪 для работы
            </span>
          )}
          <span className="quest-logo-text">GLORYHOLE QUEST</span>
        </div>
      </button>

      {/* Блок игрока и дня */}
      <div className="player-info-box">
        <div className="player-info-header">
          <span className="player-name">🏠 {player.name}</span>
          <span className="day-display">📅 День {day}</span>
        </div>
        
        {/* Репутация в том же блоке */}
        <div className="reputation-mini">
          <span className="rep-level">🏆 {reputation.levelName}</span>
          <div className="rep-mini-progress">
            <div
              className="rep-mini-bar"
              style={{ width: `${Math.min(100, (reputation.reputation / 100) * 100)}%` }}
            />
          </div>
          <span className="rep-stats-mini">{reputation.satisfactionRate}% удовл.</span>
        </div>
      </div>

      {/* Инфоблок - статы в 2 строки */}
      <div className="hub-stats-grid">
        <div className="stats-row">
          <div className="stat-item stamina-stat">
            <span className="stat-icon">💪</span>
            <span className="stat-value">{player.stats.stamina}/{player.stats.maxStamina}</span>
          </div>
          <div className="stat-divider">|</div>
          <div className="stat-item mental-stat">
            <span className="stat-icon">🧠</span>
            <span className="stat-value">{player.stats.mental_health}/{player.stats.maxMentalHealth}</span>
          </div>
          <div className="stat-divider">|</div>
          <div className="stat-item actions-stat">
            <span className="stat-icon">⚡</span>
            <span className="stat-value">
              {actionPoints}/{maxActionPoints}
              {actionPointsBonus > 0 && (
                <span style={{color: '#4ade80', marginLeft: '4px'}}>(+{actionPointsBonus})</span>
              )}
            </span>
          </div>
        </div>
        <div className="stats-row">
          <div className="stat-item money-stat">
            <span className="stat-icon">💰</span>
            <span className="stat-value">${player.stats.money}</span>
          </div>
          <div className="stat-divider">|</div>
          <div className="stat-item level-stat">
            <span className="stat-icon">⭐</span>
            <span className="stat-value">ур. {player.stats.level}</span>
          </div>
          <div className="stat-divider">|</div>
          <div className="stat-item xp-stat">
            <span className="stat-icon">✨</span>
            <span className="stat-value">{player.stats.xp} XP</span>
          </div>
        </div>
      </div>

      {/* Быстрые действия */}
      <div className="hub-quick-actions">
        <button
          className="quick-action-btn rest-btn"
          onClick={handleRest}
          title="Отдохнуть и перейти к следующему дню"
          disabled={!canRest || performingAction}
        >
          <span className="action-icon">🌙</span>
          <span className="action-text">Отдохнуть</span>
          {canRest ? (
            <span className="action-subtext">День {day} → {day + 1}</span>
          ) : (
            <span className="action-subtext" style={{color: '#888'}}>Сначала в смену!</span>
          )}
        </button>

        <button
          className="quick-action-btn"
          onClick={handleRestoreStamina}
          disabled={player.stats.stamina >= player.stats.maxStamina || performingAction}
        >
          <span className="action-icon">💤</span>
          <span className="action-text">Отдых</span>
          <span className="action-cost">-$20</span>
        </button>

        <button
          className="quick-action-btn"
          onClick={handleRestoreMental}
          disabled={player.stats.mental_health >= player.stats.maxMentalHealth || performingAction}
        >
          <span className="action-icon">🛁</span>
          <span className="action-text">Ванна</span>
          <span className="action-cost">-$30</span>
        </button>
      </div>

      {/* Кнопки навыков и магазина в одну линию */}
      <div className="hub-buttons-row">
        <button
          className="hub-action-btn skills-btn"
          onClick={() => setShowSkillsOverlay(true)}
          disabled={performingAction}
        >
          <span className="btn-icon">📚</span>
          <span className="btn-text">Навыки</span>
        </button>

        <button
          className="hub-action-btn shop-btn"
          onClick={() => setShowShopOverlay(true)}
          disabled={performingAction}
        >
          <span className="btn-icon">🛍️</span>
          <span className="btn-text">Магазин</span>
        </button>
      </div>

      {/* Домашние действия с очками действий */}
      {energyActions.length > 0 && (
        <div className="home-actions-section">
          <h3 className="home-actions-title">
            ⚡ Действия ({actionPoints}/{maxActionPoints}
            {actionPointsBonus > 0 && ` +${actionPointsBonus} бонус`}
            )
          </h3>

          <div className="home-actions-grid">
            {energyActions.map(action => (
              <button
                key={action.id}
                className={`home-action-btn ${performingAction?.actionId === action.id ? 'performing' : ''}`}
                onClick={() => handleHomeAction(action.id, action.name)}
                disabled={performingAction || actionPoints < 1}
              >
                <span className="home-action-icon">{action.icon}</span>
                <span className="home-action-name">{action.name}</span>
                <span className="home-action-effect">{action.effect}</span>
                {performingAction?.actionId === action.id && (
                  <>
                    <div className="action-progress-bar">
                      <div className="action-progress-fill" />
                    </div>
                    <span className="action-performing-text">...</span>
                  </>
                )}
              </button>
            ))}
          </div>
        </div>
      )}

      {/* Оверлей навыков */}
      {showSkillsOverlay && (
        <div className="skills-overlay" onClick={() => setShowSkillsOverlay(false)}>
          <div className="skills-overlay-content" onClick={(e) => e.stopPropagation()}>
            <div className="skills-overlay-header">
              <h2>📚 Навыки</h2>
              <button
                className="close-overlay-btn"
                onClick={() => setShowSkillsOverlay(false)}
              >
                ✕
              </button>
            </div>

            <div className="skills-overlay-list">
              {skills.map(skill => (
                <div key={skill.id} className="skill-card">
                  <div className="skill-card-header">
                    <div className="skill-card-info">
                      <span className="skill-card-name">{skill.name}</span>
                      <span className="skill-card-level">ур. {skill.level}/{skill.maxLevel}</span>
                    </div>
                  </div>

                  <p className="skill-card-desc">{skill.description}</p>

                  <div className="skill-card-progress">
                    <div className="skill-progress-bar">
                      <div
                        className="skill-progress-fill"
                        style={{ width: `${(skill.level / skill.maxLevel) * 100}%` }}
                      />
                    </div>
                  </div>

                  <button
                    className={`skill-upgrade-btn ${isMaxLevel(skill) ? 'max-level' : ''} ${!canAffordUpgrade(skill.id) ? 'cant-afford' : ''}`}
                    onClick={() => handleUpgradeSkill(skill.id)}
                    disabled={isMaxLevel(skill) || !canAffordUpgrade(skill.id)}
                  >
                    {isMaxLevel(skill) ? (
                      'МАКСИМУМ'
                    ) : (
                      <>
                        ✨ {upgradeCosts[skill.id]} XP → ур. {skill.level + 1}
                      </>
                    )}
                  </button>
                </div>
              ))}
            </div>
          </div>
        </div>
      )}

      {/* Оверлей магазина */}
      {showShopOverlay && (
        <div className="skills-overlay" onClick={() => setShowShopOverlay(false)}>
          <div className="skills-overlay-content" onClick={(e) => e.stopPropagation()}>
            <div className="skills-overlay-header">
              <h2>🛍️ Магазин</h2>
              <button
                className="close-overlay-btn"
                onClick={() => setShowShopOverlay(false)}
              >
                ✕
              </button>
            </div>

            <div className="skills-overlay-list">
              {shopItems.map(item => {
                const itemOwned = hasItem(item.id);
                const canAfford = canAffordItem(item.id);
                const isConsumable = item.category === 'consumable';

                return (
                  <div key={item.id} className="skill-card">
                    <div className="skill-card-header">
                      <div className="skill-card-info">
                        <span className="skill-card-name">
                          {item.icon} {item.name}
                        </span>
                        <span className="skill-card-level">
                          {itemOwned && !isConsumable ? '✅' : `$${item.price}`}
                        </span>
                      </div>
                    </div>

                    <p className="skill-card-desc">{item.description}</p>

                    <button
                      className={`skill-upgrade-btn ${itemOwned && !isConsumable ? 'max-level' : ''} ${!canAfford ? 'cant-afford' : ''}`}
                      onClick={() => handleBuyItem(item.id)}
                      disabled={itemOwned && !isConsumable}
                    >
                      {itemOwned && !isConsumable ? (
                        'КУПЛЕНО'
                      ) : (
                        <>
                          💰 ${item.price}
                        </>
                      )}
                    </button>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      )}

      {/* Стили */}
      <style>{`
        .hub-screen {
          padding: 12px;
          justify-content: flex-start;
        }

        /* Логотип игры */
        .quest-logo-button {
          width: 100%;
          max-width: 350px;
          margin: 0 auto 12px;
          padding: 18px 24px;
          background: linear-gradient(135deg, #e94560 0%, #c73659 100%);
          border: 2px solid rgba(233, 69, 96, 0.5);
          border-radius: 12px;
          cursor: pointer;
          transition: all 0.3s ease;
          box-shadow: 0 4px 15px rgba(233, 69, 96, 0.3);
          overflow: hidden;
        }

        .quest-logo-button:hover:not(:disabled) {
          transform: translateY(-3px);
          box-shadow: 0 6px 25px rgba(233, 69, 96, 0.5);
        }

        .quest-logo-button:disabled {
          opacity: 0.5;
          cursor: not-allowed;
        }

        .quest-logo-text {
          font-size: 16px;
          font-weight: 900;
          color: #fff;
          letter-spacing: 2px;
          text-shadow: 0 2px 4px rgba(0,0,0,0.4);
          white-space: nowrap;
        }

        .quest-logo-content {
          display: flex;
          flex-direction: column;
          align-items: center;
          gap: 6px;
        }

        .rest-warning {
          font-size: 11px;
          color: #fbbf24;
          font-weight: bold;
          text-transform: uppercase;
          letter-spacing: 1px;
        }

        /* Блок игрока */
        .player-info-box {
          background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.05) 100%);
          border: 1px solid rgba(255, 255, 255, 0.2);
          border-radius: 12px;
          padding: 12px;
          margin-bottom: 12px;
        }

        .player-info-header {
          display: flex;
          justify-content: space-between;
          align-items: center;
          margin-bottom: 10px;
        }

        .player-name {
          font-size: 14px;
          color: #e94560;
          font-weight: bold;
        }

        .day-display {
          font-size: 12px;
          color: #a78bfa;
        }

        .reputation-mini {
          display: flex;
          align-items: center;
          gap: 8px;
          padding-top: 8px;
          border-top: 1px solid rgba(255, 255, 255, 0.1);
        }

        .rep-level {
          font-size: 11px;
          color: #a78bfa;
          white-space: nowrap;
        }

        .rep-mini-progress {
          flex: 1;
          height: 6px;
          background: rgba(255, 255, 255, 0.1);
          border-radius: 3px;
          overflow: hidden;
        }

        .rep-mini-bar {
          height: 100%;
          background: linear-gradient(90deg, #a78bfa 0%, #8b5cf6 100%);
          transition: width 0.3s ease;
        }

        .rep-stats-mini {
          font-size: 9px;
          color: #888;
          white-space: nowrap;
        }

        /* Статы в 2 строки */
        .hub-stats-grid {
          display: flex;
          flex-direction: column;
          gap: 8px;
          margin-bottom: 12px;
        }

        .stats-row {
          display: flex;
          align-items: center;
          justify-content: space-between;
          background: rgba(255, 255, 255, 0.05);
          border: 1px solid rgba(233, 69, 96, 0.3);
          border-radius: 10px;
          padding: 10px 8px;
          gap: 4px;
        }

        .stat-item {
          display: flex;
          align-items: center;
          gap: 4px;
          font-size: 10px;
          flex: 1;
          justify-content: center;
        }

        .stat-icon {
          font-size: 12px;
        }

        .stat-value {
          color: #f0f0f0;
          white-space: nowrap;
        }

        .stat-divider {
          color: rgba(255, 255, 255, 0.2);
          font-size: 8px;
        }

        .stamina-stat .stat-value { color: #4ade80; }
        .mental-stat .stat-value { color: #60a5fa; }
        .money-stat .stat-value { color: #fbbf24; }
        .level-stat .stat-value { color: #f472b6; }
        .actions-stat .stat-value { color: #f97316; }
        .xp-stat .stat-value { color: #a78bfa; }

        /* Быстрые действия */
        .hub-quick-actions {
          display: flex;
          gap: 8px;
          margin-bottom: 12px;
          flex-wrap: wrap;
        }

        .quick-action-btn {
          flex: 1;
          min-width: 70px;
          padding: 10px 6px;
          background: rgba(255, 255, 255, 0.08);
          border: 1px solid rgba(255, 255, 255, 0.15);
          border-radius: 8px;
          display: flex;
          flex-direction: column;
          align-items: center;
          gap: 3px;
          cursor: pointer;
          transition: all 0.2s ease;
        }

        .quick-action-btn:hover:not(:disabled) {
          background: rgba(255, 255, 255, 0.12);
          border-color: rgba(233, 69, 96, 0.4);
        }

        .quick-action-btn:disabled {
          opacity: 0.4;
          cursor: not-allowed;
        }

        .action-icon {
          font-size: 18px;
        }

        .action-text {
          font-size: 9px;
          color: #f0f0f0;
        }

        .action-cost {
          font-size: 8px;
          color: #fbbf24;
        }

        .action-subtext {
          font-size: 7px;
          color: #a78bfa;
        }

        .rest-btn {
          background: linear-gradient(135deg, rgba(167, 139, 250, 0.25) 0%, rgba(139, 92, 246, 0.15) 100%);
          border-color: rgba(167, 139, 250, 0.5);
        }

        /* Кнопки навыков и магазина */
        .hub-buttons-row {
          display: flex;
          gap: 10px;
          margin-bottom: 15px;
        }

        .hub-action-btn {
          flex: 1;
          padding: 12px 15px;
          border-radius: 10px;
          border: none;
          display: flex;
          align-items: center;
          justify-content: center;
          gap: 8px;
          cursor: pointer;
          transition: all 0.2s ease;
          font-weight: bold;
        }

        .hub-action-btn:disabled {
          opacity: 0.5;
          cursor: not-allowed;
        }

        .btn-icon {
          font-size: 20px;
        }

        .btn-text {
          font-size: 12px;
          color: #fff;
        }

        .skills-btn {
          background: linear-gradient(135deg, rgba(233, 69, 96, 0.3) 0%, rgba(199, 54, 89, 0.2) 100%);
          border: 1px solid rgba(233, 69, 96, 0.5);
        }

        .skills-btn:hover:not(:disabled) {
          background: linear-gradient(135deg, rgba(233, 69, 96, 0.4) 0%, rgba(199, 54, 89, 0.3) 100%);
          border-color: rgba(233, 69, 96, 0.7);
        }

        .shop-btn {
          background: linear-gradient(135deg, rgba(167, 139, 250, 0.3) 0%, rgba(139, 92, 246, 0.2) 100%);
          border: 1px solid rgba(167, 139, 250, 0.5);
        }

        .shop-btn:hover:not(:disabled) {
          background: linear-gradient(135deg, rgba(167, 139, 250, 0.4) 0%, rgba(139, 92, 246, 0.3) 100%);
          border-color: rgba(167, 139, 250, 0.7);
        }

        /* Домашние действия */
        .home-actions-section {
          margin-bottom: 15px;
        }

        .home-actions-title {
          font-size: 12px;
          color: #e94560;
          margin: 0 0 10px 0;
          text-shadow: 0 0 5px rgba(233, 69, 96, 0.5);
        }

        .home-actions-grid {
          display: flex;
          gap: 8px;
          flex-wrap: wrap;
        }

        .home-action-btn {
          flex: 1;
          min-width: 80px;
          padding: 10px 8px;
          background: rgba(255, 255, 255, 0.08);
          border: 1px solid rgba(255, 255, 255, 0.15);
          border-radius: 8px;
          display: flex;
          flex-direction: column;
          align-items: center;
          gap: 4px;
          cursor: pointer;
          transition: all 0.2s ease;
          position: relative;
        }

        .home-action-btn:hover:not(:disabled) {
          background: rgba(255, 255, 255, 0.12);
          border-color: rgba(233, 69, 96, 0.4);
        }

        .home-action-btn:disabled {
          opacity: 0.4;
          cursor: not-allowed;
        }

        .home-action-btn.performing {
          background: rgba(167, 139, 250, 0.2);
          border-color: rgba(167, 139, 250, 0.6);
        }

        .home-action-icon {
          font-size: 20px;
        }

        .home-action-name {
          font-size: 10px;
          color: #f0f0f0;
        }

        .home-action-effect {
          font-size: 9px;
          color: #4ade80;
        }

        .action-progress-bar {
          position: absolute;
          bottom: 0;
          left: 0;
          right: 0;
          height: 3px;
          background: rgba(255, 255, 255, 0.1);
          border-radius: 0 0 8px 8px;
          overflow: hidden;
        }

        .action-progress-fill {
          height: 100%;
          background: linear-gradient(90deg, #a78bfa 0%, #8b5cf6 100%);
          animation: progress 1.5s ease-in-out infinite;
        }

        @keyframes progress {
          0% { width: 0%; }
          50% { width: 100%; }
          100% { width: 0%; }
        }

        .action-performing-text {
          font-size: 8px;
          color: #a78bfa;
          margin-top: 2px;
        }

        /* Уведомления */
        .notification {
          position: fixed;
          top: 20px;
          left: 50%;
          transform: translateX(-50%);
          padding: 12px 20px;
          border-radius: 10px;
          font-size: 12px;
          font-weight: bold;
          z-index: 1000;
          box-shadow: 0 4px 15px rgba(0,0,0,0.3);
          animation: slideDown 0.3s ease;
        }

        @keyframes slideDown {
          from {
            opacity: 0;
            transform: translate(-50%, -20px);
          }
          to {
            opacity: 1;
            transform: translate(-50%, 0);
          }
        }

        .notification-success {
          background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
          color: #fff;
        }

        .notification-error {
          background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
          color: #fff;
        }

        .notification-info {
          background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
          color: #fff;
        }

        .warning-text {
          font-size: 10px;
          color: #fbbf24;
          text-align: center;
          margin: 5px 0;
        }

        /* Оверлей */
        .skills-overlay {
          position: fixed;
          top: 0;
          left: 0;
          right: 0;
          bottom: 0;
          background: rgba(0, 0, 0, 0.85);
          display: flex;
          align-items: center;
          justify-content: center;
          z-index: 100;
          padding: 20px;
        }

        .skills-overlay-content {
          background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
          border: 2px solid rgba(233, 69, 96, 0.3);
          border-radius: 15px;
          max-width: 400px;
          width: 100%;
          max-height: 80vh;
          overflow-y: auto;
          padding: 20px;
        }

        .skills-overlay-header {
          display: flex;
          justify-content: space-between;
          align-items: center;
          margin-bottom: 20px;
        }

        .skills-overlay-header h2 {
          font-size: 18px;
          color: #e94560;
          margin: 0;
        }

        .close-overlay-btn {
          background: none;
          border: none;
          color: #e94560;
          font-size: 24px;
          cursor: pointer;
          padding: 0;
          width: 30px;
          height: 30px;
          display: flex;
          align-items: center;
          justify-content: center;
        }

        .skills-overlay-list {
          display: flex;
          flex-direction: column;
          gap: 12px;
        }

        .skill-card {
          background: rgba(255, 255, 255, 0.05);
          border: 1px solid rgba(255, 255, 255, 0.1);
          border-radius: 10px;
          padding: 12px;
        }

        .skill-card-header {
          display: flex;
          justify-content: space-between;
          align-items: center;
          margin-bottom: 8px;
        }

        .skill-card-info {
          display: flex;
          flex-direction: column;
          gap: 4px;
        }

        .skill-card-name {
          font-size: 13px;
          color: #f0f0f0;
          font-weight: bold;
        }

        .skill-card-level {
          font-size: 11px;
          color: #a78bfa;
        }

        .skill-card-desc {
          font-size: 10px;
          color: #888;
          margin: 0 0 10px 0;
        }

        .skill-card-progress {
          margin-bottom: 10px;
        }

        .skill-progress-bar {
          height: 6px;
          background: rgba(255, 255, 255, 0.1);
          border-radius: 3px;
          overflow: hidden;
        }

        .skill-progress-fill {
          height: 100%;
          background: linear-gradient(90deg, #a78bfa 0%, #8b5cf6 100%);
          transition: width 0.3s ease;
        }

        .skill-upgrade-btn {
          width: 100%;
          padding: 8px;
          border-radius: 6px;
          border: none;
          font-size: 11px;
          font-weight: bold;
          cursor: pointer;
          transition: all 0.2s ease;
        }

        .skill-upgrade-btn:not(:disabled):hover {
          transform: translateY(-1px);
        }

        .skill-upgrade-btn:not(.max-level):not(.cant-afford) {
          background: linear-gradient(135deg, #a78bfa 0%, #8b5cf6 100%);
          color: #fff;
        }

        .skill-upgrade-btn.max-level {
          background: rgba(255, 255, 255, 0.1);
          color: #888;
        }

        .skill-upgrade-btn.cant-afford {
          background: rgba(255, 255, 255, 0.05);
          color: #666;
        }
      `}</style>
    </div>
  );
}

export default HubScreen;
